{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "expo export --platform web && node scripts/inject-pwa.mjs",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/((?!.well-known/|.*\\..*).*)", "destination": "/index.html" }
  ]
}
